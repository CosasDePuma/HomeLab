{
    "version": "2",
    "templates": [
        {
            "type": 1,
            "categories": [
                "Dashboard",
                "Open Source"
            ],
            "title": "Homer",
            "note": "<p><a href=\"https://github.com/bastienwirtz/homer\" target=\"_blank\">Homer</a> template by <a href=\"https://www.github.com/cosasdepuma\" target=\"_blank\">@cosasdepuma</a> based on data provided by <a href=\"https://github.com/bastienwirtz/homer#getting-started\" target=\"_blank\">@bastienwirtz</a>.</p>",
            "description": "Homer is a very simple static homepage for your server. A dead simple static HOMepage for your servER to keep your services on hand, from a simple yaml configuration file.",
            "logo": "https://raw.githubusercontent.com/bastienwirtz/homer/main/public/logo.png",
            "image": "b4bz/homer:latest",
            "name": "homer",
            "platform": "linux",
            "network": "bridge",
            "hostname": "simpson",
            "ports": [
                "80:8080/tcp"
            ],
            "env": [
                {
                    "name": "SUBFOLDER",
                    "label": "SUBFOLDER",
                    "default": "",
                    "description": "If you would like to host Homer in a subfolder (ex: http://example.com/homer), set this to the subfolder path (ex: /homer)"
                },
                {
                    "name": "INIT_ASSETS",
                    "label": "ASSETS",
                    "select": [
                        {
                            "default": true,
                            "text": "Empty",
                            "value": "0"
                        },
                        {
                            "text": "Default",
                            "value": "1"
                        }
                    ],
                    "description": "Install example configuration file and assets (favicons, css, ...) to help you get started."
                }
            ],
            "volumes": [
                {
                    "container": "/www/assets",
                    "bind": "/data/config/homer"
                }
            ],
            "restart_policy": "unless-stopped"
        },
        {
            "type": 1,
            "categories": [
                "Ansible",
                "Management",
                "Network",
                "Open Source"
            ],
            "title": "Semaphore",
            "note": "<p><a href=\"https://www.ansible-semaphore.com\" target=\"_blank\">Semaphore</a> template by <a href=\"https://www.github.com/cosasdepuma\" target=\"_blank\">@cosasdepuma</a> based on data provided by <a href=\"https://docs.ansible-semaphore.com/administration-guide/installation\" target=\"_blank\">linuxserver.io</a>.</p>",
            "description": "Ansible Semaphore is a modern UI for Ansible. It lets you easily run Ansible playbooks, get notifications about fails, control access to deployment system.",
            "logo": "https://raw.githubusercontent.com/cosasdepuma/homelab/main/services/homer/www/icons/semaphore.png",
            "image": "semaphoreui/semaphore:latest",
            "name": "semaphore",
            "platform": "linux",
            "network": "bridge",
            "hostname": "signal",
            "ports": [
                "3000:3000/tcp"
            ],
            "env": [
                {
                    "name": "SEMAPHORE_ADMIN",
                    "label": "USERNAME",
                    "default": "semaphore",
                    "description": "Admin username"
                },
                {
                    "name": "SEMAPHORE_ADMIN_PASSWORD",
                    "label": "PASSWORD",
                    "default": "semaphore",
                    "description": "Admin password"
                },
                {
                    "name": "SEMAPHORE_ADMIN_EMAIL",
                    "label": "EMAIL",
                    "default": "admin@localhost",
                    "description": "Admin email"
                },
                {
                    "name": "SEMAPHORE_ADMIN_NAME",
                    "default": "Administrator",
                    "preset": true
                },
                {
                    "name": "SEMAPHORE_DB_DIALECT",
                    "default": "bolt",
                    "preset": true
                },
                {
                    "name": "SEMAPHORE_PLAYBOOK_PATH",
                    "default": "/playbooks",
                    "preset": true
                }
            ],
            "volumes": [
                {
                    "container": "/etc/semaphore",
                    "bind": "/data/config/semaphore"
                },
                {
                    "container": "/var/lib/semaphore",
                    "bind": "/data/database/semaphore"
                },
                {
                    "container": "/playbooks",
                    "bind": "/data/ansible"
                }
            ],
            "restart_policy": "unless-stopped"
        },
        {
            "type": 1,
            "categories": [
                "Management",
                "Network",
                "Open Source",
                "Reverse Proxy"
            ],
            "title": "Traefik Proxy",
            "note": "<p><a href=\"https://traefik.io/traefik/\" target=\"_blank\">Traefik Proxy</a> template by <a href=\"https://www.github.com/cosasdepuma\" target=\"_blank\">@cosasdepuma</a> based on data provided by <a href=\"https://doc.traefik.io/traefik/\" target=\"_blank\">Traefik</a>.</p>",
            "description": "Traefik is an open-source Edge Router that makes publishing your services a fun and easy experience. It receives requests on behalf of your system and finds out which components are responsible for handling them.",
            "logo": "https://raw.githubusercontent.com/cosasdepuma/homelab/main/services/homer/www/icons/traefik.png",
            "image": "traefik:latest",
            "name": "traefik",
            "platform": "linux",
            "network": "bridge",
            "hostname": "traffic",
            "ports": [
                "80:80/tcp",
                "443:443/tcp",
                "8080:8080/tcp"
            ],
            "volumes": [
                {
                    "container": "/var/run/docker.sock",
                    "bind": "/var/run/docker.sock"
                },
                {
                    "container": "/etc/traefik",
                    "bind": "/data/config/traefik"
                }
            ],
            "restart_policy": "unless-stopped"
        },
        {
            "type": 1,
            "categories": [
                "Development",
                "IDE",
                "Productivity"
            ],
            "title": "VSCode",
            "note": "<p><a href=\"https://coder.com\" target=\"_blank\">VSCode Server</a> template by <a href=\"https://www.github.com/cosasdepuma\" target=\"_blank\">@cosasdepuma</a> based on data provided by <a href=\"https://docs.linuxserver.io/images/docker-code-server\" target=\"_blank\">linuxserver.io</a>.</p>",
            "description": "VS Code running on a remote server, accessible through the browser.",
            "logo": "https://raw.githubusercontent.com/cosasdepuma/homelab/main/services/homer/www/icons/vscode.png",
            "image": "linuxserver/code-server:latest",
            "name": "vscode",
            "platform": "linux",
            "network": "bridge",
            "hostname": "workbench",
            "ports": [
                "8443:8443/tcp"
            ],
            "env": [
                {
                    "name": "PUID",
                    "label": "UID",
                    "default": "1000",
                    "description": "User ID"
                },
                {
                    "name": "PGID",
                    "label": "GID",
                    "default": "1000",
                    "description": "Group ID"
                },
                {
                    "name": "TZ",
                    "label": "TZ",
                    "default": "Europe/Madrid",
                    "description": "Timezone"
                },
                {
                    "name": "PASSWORD",
                    "label": "PASSWORD",
                    "default": "user",
                    "description": "Web application password"
                },
                {
                    "name": "SUDO_PASSWORD",
                    "label": "SUDO PASSWORD",
                    "default": "toor",
                    "description": "Sudo password"
                },
                {
                    "name": "DEFAULT_WORKSPACE",
                    "default": "/workspace",
                    "preset": true
                }
            ],
            "volumes": [
                {
                    "container": "/config",
                    "bind": "/data/config/vscode"
                },
                {
                    "container": "/workspace",
                    "bind": "/data/projects"
                }
            ],
            "restart_policy": "unless-stopped"
        },
        {
            "type": 3,
            "categories": [
                "Network",
                "Security",
                "Open Source",
                "VPN"
            ],
            "title": "WireGuard",
            "note": "<p><a href=\"https://www.wireguard.com\" target=\"_blank\">WireGuard</a> template by <a href=\"https://www.github.com/cosasdepuma\" target=\"_blank\">@cosasdepuma</a> based on data provided by <a href=\"https://docs.linuxserver.io/images/docker-wireguard\" target=\"_blank\">linuxserver.io</a>.</p>",
            "description": "WireGuard is an extremely simple yet fast and modern VPN that utilizes state-of-the-art cryptography. It aims to be faster, simpler, leaner, and more useful than IPsec, while avoiding the massive headache. It intends to be considerably more performant than OpenVPN. WireGuard is designed as a general purpose VPN for running on embedded interfaces and super computers alike, fit for many different circumstances.",
            "logo": "https://raw.githubusercontent.com/cosasdepuma/homelab/main/services/homer/www/icons/wireguard.png",
            "image": "linuxserver/wireguard:latest",
            "name": "wireguard",
            "platform": "linux",
            "repository": {
                "url": "https://github.com/cosasdepuma/homelab",
                "stackfile": "services/wireguard/docker-compose.yml"
            },
            "env": [
                {
                    "name": "WIREGUARD_CONFIG",
                    "label": "CONFIG",
                    "default": "/data/config/wireguard",
                    "description": "Path to the wireguard config folder"
                },
                {
                    "name": "WIREGUARD_TZ",
                    "label": "TZ",
                    "default": "Europe/Madrid",
                    "description": "Timezone"
                },
                {
                    "name": "WIREGUARD_DOMAIN",
                    "label": "DOMAIN",
                    "default": "",
                    "description": "Domain name for the VPN server. If you don't have one, you can use the server's IP address."
                },
                {
                    "name": "WIREGUARD_PORT",
                    "label": "PORT",
                    "default": "51820",
                    "description": "UDP connection port. Remember to update the exposed docker ports."
                },
                {
                    "name": "WIREGUARD_PEERS",
                    "label": "PEERS",
                    "default": "laptop,computer,phone,tablet,tv",
                    "description": "Number of clients (peers). Can also be a list of names: `android,ios,tv,computer` (alphanumeric only)"
                },
                {
                    "name": "WIREGUARD_SUBNET",
                    "label": "SUBNET",
                    "default": "10.10.10.0",
                    "description": "Internal subnet for the wireguard and server and clients."
                },
                {
                    "name": "WIREGUARD_DNS",
                    "label": "DNS",
                    "default": "10.10.10.1,1.1.1.1",
                    "description": "DNS server set in client configs (can be set as `1.1.1.1`). Defaults to `auto`, which uses internal DNS via included CoreDNS forward."
                },
                {
                    "name": "WIREGUARD_ALLOWEDIPS",
                    "label": "ALLOWED IPS",
                    "default": "10.10.0.1,192.168.0.0/23",
                    "description": "The IPs/ranges (separated by commas) that the clients will be able to reach using the VPN connection. If you want split tunneling, set this to only the IPs you would like to use the tunnel AND the ip of the server's WG IP, such as 10.10.0.1."
                },
                {
                    "name": "LOG_CONFS",
                    "default": "false",
                    "preset": true
                }
            ]
        }
    ]
}