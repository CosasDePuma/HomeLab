{
    "version": "2",
    "templates": [
        {
            "type": 1,
            "categories": [
                "Media",
                "Movies",
                "Open Source",
                "Series",
                "Subtitles"
            ],
            "title": "Bazarr",
            "note": "<p><a href=\"https://www.bazarr.media\" target=\"_blank\">Bazarr</a> template by <a href=\"https://www.github.com/cosasdepuma\" target=\"_blank\">@cosasdepuma</a> based on data provided by <a href=\"https://docs.linuxserver.io/images/docker-bazarr\" target=\"_blank\">linuxserver.io</a>.</p>",
            "description": "Bazarr is a companion application to Sonarr and Radarr. It can manage and download subtitles based on your requirements. You define your preferences by TV show or movie and Bazarr takes care of everything for you.",
            "logo": "https://raw.githubusercontent.com/linuxserver/docker-templates/master/linuxserver.io/img/bazarr.png",
            "image": "linuxserver/bazarr:latest",
            "name": "bazarr",
            "platform": "linux",
            "network": "bridge",
            "hostname": "aladin",
            "ports": [
                "6767:6767/tcp"
            ],
            "env": [
                {
                    "name": "PUID",
                    "label": "UID",
                    "default": "0",
                    "description": "User ID"
                },
                {
                    "name": "PGID",
                    "label": "GID",
                    "default": "0",
                    "description": "Group ID"
                },
                {
                    "name": "TZ",
                    "label": "TZ",
                    "default": "Europe/Madrid",
                    "description": "Timezone"
                }
            ],
            "volumes": [
                {
                    "container": "/config",
                    "bind": "/data/config/bazarr"
                },
                {
                    "container": "/media",
                    "bind": "/data/media"
                }
            ],
            "restart_policy": "unless-stopped"
        },
        {
            "type": 1,
            "categories": [
                "Dashboard",
                "Open Source"
            ],
            "title": "Homer",
            "note": "<p><a href=\"https://github.com/bastienwirtz/homer\" target=\"_blank\">Homer</a> template by <a href=\"https://www.github.com/cosasdepuma\" target=\"_blank\">@cosasdepuma</a> based on data provided by <a href=\"https://github.com/bastienwirtz/homer#getting-started\" target=\"_blank\">@bastienwirtz</a>.</p>",
            "description": "Homer is a very simple static homepage for your server. A dead simple static HOMepage for your servER to keep your services on hand, from a simple yaml configuration file.",
            "logo": "https://raw.githubusercontent.com/bastienwirtz/homer/main/public/logo.png",
            "image": "b4bz/homer:latest",
            "name": "homer",
            "platform": "linux",
            "network": "bridge",
            "hostname": "simpson",
            "ports": [
                "80:8080/tcp"
            ],
            "env": [
                {
                    "name": "SUBFOLDER",
                    "label": "SUBFOLDER",
                    "default": "",
                    "description": "If you would like to host Homer in a subfolder (ex: http://example.com/homer), set this to the subfolder path (ex: /homer)"
                },
                {
                    "name": "INIT_ASSETS",
                    "label": "ASSETS",
                    "select": [
                        {
                            "default": true,
                            "text": "Empty",
                            "value": "0"
                        },
                        {
                            "text": "Default",
                            "value": "1"
                        }
                    ],
                    "description": "Install example configuration file and assets (favicons, css, ...) to help you get started."
                }
            ],
            "volumes": [
                {
                    "container": "/www/assets",
                    "bind": "/data/config/homer"
                }
            ],
            "restart_policy": "unless-stopped"
        },
        {
            "type": 1,
            "categories": [
                "Cybersecurity",
                "Vulnerability Scanner"
            ],
            "title": "Nessus",
            "note": "<p><a href=\"https://www.tenable.com/products/nessus\" target=\"_blank\">Nessus</a> template by <a href=\"https://www.github.com/cosasdepuma\" target=\"_blank\">@cosasdepuma</a> based on data provided by <a href=\"https://docs.tenable.com/nessus/Content/DeployNessusDocker.htm\" target=\"_blank\">Tenable</a>.</p>",
            "description": "Nessus is a vulnerability scanning program for various operating systems. It consists of a daemon or devil, nessusd, which performs the scan on the target system, and nessus, the client which displays the progress and reports on the status of the scans.",
            "logo": "https://www.gravatar.com/avatar/d27f61b9faa8533c9764d369a7293231",
            "image": "tenable/nessus:latest-ubuntu",
            "name": "nessus",
            "platform": "linux",
            "network": "bridge",
            "hostname": "centaur",
            "ports": [
                "8834:8834/tcp"
            ],
            "env": [
                {
                    "name": "USERNAME",
                    "label": "USERNAME",
                    "default": "auditor",
                    "description": "Username"
                },
                {
                    "name": "PASSWORD",
                    "label": "PASSWORD",
                    "default": "nessus",
                    "description": "Password"
                },
                {
                    "name": "ACTIVATION_CODE",
                    "label": "ACTIVATION CODE",
                    "default": "",
                    "description": "Nessus Pro activation code"
                }
            ],
            "volumes": [
                {
                    "container": "/opt/nessus/etc/nessus/",
                    "bind": "/data/config/nessus"
                }
            ],
            "restart_policy": "unless-stopped"
        },
        {
            "type": 1,
            "categories": [
                "Media",
                "Open Source",
                "Torrent"
            ],
            "title": "Prowlarr",
            "note": "<p><a href=\"https://github.com/Prowlarr/Prowlarr\" target=\"_blank\">Prowlarr</a> template by <a href=\"https://www.github.com/cosasdepuma\" target=\"_blank\">@cosasdepuma</a> based on data provided by <a href=\"https://docs.linuxserver.io/images/docker-prowlarr\" target=\"_blank\">linuxserver.io</a>.</p>",
            "description": "Prowlarr is an indexer manager/proxy built on the popular *arr .net/reactjs base stack to integrate with your various PVR apps. Prowlarr supports management of both Torrent Trackers and Usenet Indexers. It integrates seamlessly with Lidarr, Mylar3, Radarr, Readarr and Sonarr.",
            "logo": "https://raw.githubusercontent.com/linuxserver/docker-templates/master/linuxserver.io/img/prowlarr-banner.png",
            "image": "linuxserver/prowlarr:latest",
            "name": "prowlarr",
            "platform": "linux",
            "network": "bridge",
            "hostname": "taiga",
            "ports": [
                "9696:9696/tcp"
            ],
            "env": [
                {
                    "name": "PUID",
                    "label": "UID",
                    "default": "1000",
                    "description": "User ID"
                },
                {
                    "name": "PGID",
                    "label": "GID",
                    "default": "1000",
                    "description": "Group ID"
                },
                {
                    "name": "TZ",
                    "label": "TZ",
                    "default": "Europe/Madrid",
                    "description": "Timezone"
                }
            ],
            "volumes": [
                {
                    "container": "/config",
                    "bind": "/data/config/prowlarr"
                }
            ],
            "restart_policy": "unless-stopped"
        },
        {
            "type": 1,
            "categories": [
                "Media",
                "Open Source",
                "Torrent"
            ],
            "title": "qBittorrent",
            "note": "<p><a href=\"https://www.qbittorrent.org\" target=\"_blank\">qBittorrent</a> template by <a href=\"https://www.github.com/cosasdepuma\" target=\"_blank\">@cosasdepuma</a> based on data provided by <a href=\"https://docs.linuxserver.io/images/docker-qbittorrent\" target=\"_blank\">linuxserver.io</a>.</p>",
            "description": "Qbittorrent aims to provide an open-source software alternative to µTorrent. qBittorrent is based on the Qt toolkit and libtorrent-rasterbar library.",
            "logo": "https://raw.githubusercontent.com/linuxserver/docker-templates/master/linuxserver.io/img/qbittorrent-icon.png",
            "image": "linuxserver/qbittorrent:latest",
            "name": "qbittorrent",
            "platform": "linux",
            "network": "bridge",
            "hostname": "qubit",
            "ports": [
                "6881:6881/tcp",
                "6881:6881/udp",
                "8080:8080/tcp"
            ],
            "env": [
                {
                    "name": "PUID",
                    "label": "UID",
                    "default": "0",
                    "description": "User ID"
                },
                {
                    "name": "PGID",
                    "label": "GID",
                    "default": "0",
                    "description": "Group ID"
                },
                {
                    "name": "TZ",
                    "label": "TZ",
                    "default": "Europe/Madrid",
                    "description": "Timezone"
                },
                {
                    "name": "WEBUI_PORT",
                    "label": "WEBUI PORT",
                    "default": "8080",
                    "description": "WebUI port. Change exposed ports if you change this value."
                }
            ],
            "volumes": [
                {
                    "container": "/config",
                    "bind": "/data/config/qbittorrent"
                },
                {
                    "container": "/media",
                    "bind": "/data/media"
                },
                {
                    "container": "/downloads",
                    "bind": "/data/torrents"
                }
            ],
            "restart_policy": "unless-stopped"
        },
        {
